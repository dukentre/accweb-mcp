ACCWEB_HTTP_PORT=8080
ACCWEB_ADMIN_PASSWORD=change-me-admin
ACCWEB_MOD_PASSWORD=change-me-mod
ACCWEB_RO_PASSWORD=change-me-readonly
ACCWEB_TIMEOUT=24h
ACCWEB_LOGLEVEL=info
ACCWEB_CORS=*
ACCWEB_LOG_WITH_TIMESTAMP=true
ACCWEB_MCP_ENABLED=true
ACCWEB_MCP_TOKEN=change-me-mcp-token
ACCWEB_MCP_ALLOWED_ORIGINS=

# ACC Dedicated Server files are downloaded into /accserver.
# Put the dedicated server files on the host and mount them into /accserver.
# Expected default layout:
#   ./accserver/server/accServer.exe
ACCSERVER_HOST_PATH=./accserver
ACCWEB_ACC_SERVER_PATH=/accserver/server
ACCWEB_ACC_SERVER_EXE=accServer.exe

# Default ACC ports used by the sample server configuration.
ACC_LAN_PORT=8999
ACC_UDP_PORT=9231
ACC_TCP_PORT=9232

ACCWEB_IMAGE=accweb/accweb:local
ACCWEB_VERSION=docker
ACCWEB_COMMIT=local
ACCWEB_CONTAINER_NAME=accweb-server
