ACCWEB_IMAGE=ghcr.io/dukentre/accweb-mcp:latest
ACCWEB_CONTAINER_NAME=accweb-mcp

# Host path with manually provided ACC Dedicated Server files. This path is on
# the Linux host, not inside the container. Keep Steam login/Steam Guard outside
# Docker and copy the server files here manually.
# Expected default layout:
#   /opt/accweb-mcp/accserver/server/accServer.exe
ACCSERVER_HOST_PATH=/opt/accweb-mcp/accserver

# Path and executable name as ACCWeb sees them inside the container. These
# values match the bind mount above and usually do not need to change.
ACCWEB_ACC_SERVER_PATH=/accserver/server
ACCWEB_ACC_SERVER_EXE=accServer.exe

# Published ports. Keep ACC_UDP_PORT and ACC_TCP_PORT in sync with the values
# configured in ACCWeb/ACC configuration.json for the running instance.
ACCWEB_HTTP_PORT=8080
ACC_LAN_PORT=8999
ACC_UDP_PORT=9231
ACC_TCP_PORT=9232

# Change all passwords before starting the service. The production compose file
# refuses to start if these variables are missing.
ACCWEB_ADMIN_PASSWORD=change-me-admin
ACCWEB_MOD_PASSWORD=change-me-mod
ACCWEB_RO_PASSWORD=change-me-readonly

# ACCWeb HTTP/runtime behavior.
ACCWEB_TIMEOUT=24h
ACCWEB_ENABLE_TLS=false
ACCWEB_LOGLEVEL=info
ACCWEB_CORS=*
ACCWEB_LOG_WITH_TIMESTAMP=true

# MCP HTTP endpoint at /mcp. Use a long random token in production. Browser
# clients can be restricted with ACCWEB_MCP_ALLOWED_ORIGINS.
ACCWEB_MCP_ENABLED=true
ACCWEB_MCP_TOKEN=change-me-long-random-token
ACCWEB_MCP_ALLOWED_ORIGINS=

# Optional ACCWeb callbacks.
ACCWEB_CALLBACK_ENABLED=false
ACCWEB_CALLBACK_TIMEOUT=500ms
ACCWEB_CALLBACK_URL=
ACCWEB_CALLBACK_HEADER_KEY=
ACCWEB_CALLBACK_HEADER_VALUE=
ACCWEB_CALLBACK_EVENTS=
